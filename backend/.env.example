# Copy to .env and fill in values. .env is gitignored.

# Required
DATABASE_URL=postgres://pos:pos@postgres:5432/pos?sslmode=disable
JWT_SECRET=change-me-to-a-long-random-string

# Optional (defaults shown)
HTTP_ADDR=:8080
JWT_TOKEN_TTL=24h
BCRYPT_COST=12
CORS_ALLOW_ORIGIN=http://localhost:5173
# Set to 1 to log every SQL statement (dev only).
DEBUG_SQL=0
