# Dev-only image for `npm run dev` with hot reload.
# The source is bind-mounted from the host via docker-compose, so this image
# only installs dependencies and exposes the Vite dev server.

FROM node:22-alpine

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

EXPOSE 5173

# Bind to 0.0.0.0 so the host can reach the dev server through the port map.
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
